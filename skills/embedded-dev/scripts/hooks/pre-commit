#!/bin/sh
# embedded-dev 分层架构门禁 —— git pre-commit 钩子
#
# 目的：把 arch-check 从"会话内自觉跑"升级为"提交时强制跑"，不通过则阻断提交。
# 兼容：git 在 Windows 上也用自带 bash 跑 hooks；无 bash 时回退 pwsh 跑 arch-check.ps1。
# 跳过：本次提交不涉及 .c/.h 时直接放行；临时绕过用 `git commit --no-verify`。

# 仅当暂存区含 C/H 源文件时才跑门禁
staged=$(git diff --cached --name-only --diff-filter=ACM | grep -Ei '\.(c|h)$' 2>/dev/null || true)
if [ -z "$staged" ]; then
    exit 0
fi

ROOT=$(git rev-parse --show-toplevel 2>/dev/null || pwd)
SKILL_DIR="${EMBEDDED_DEV_DIR:-$HOME/.claude/skills/embedded-dev}"

# 解析检查脚本路径：优先工程内 scripts/，再到 skill 安装目录
find_first() {
    for p in "$@"; do
        [ -f "$p" ] && { printf '%s\n' "$p"; return 0; }
    done
    return 1
}

SH_CHECK=$(find_first "$ROOT/scripts/arch-check.sh" "$SKILL_DIR/scripts/arch-check.sh")
PS_CHECK=$(find_first "$ROOT/scripts/arch-check.ps1" "$SKILL_DIR/scripts/arch-check.ps1")

rc=0
ran=0

# 路线 1：bash + arch-check.sh（行为基准，优先）
if [ -n "$SH_CHECK" ] && command -v bash >/dev/null 2>&1; then
    ( cd "$ROOT" && bash "$SH_CHECK" --all )
    rc=$?
    ran=1
# 路线 2：pwsh + arch-check.ps1（纯 PowerShell / 无 bash 环境）
elif [ -n "$PS_CHECK" ] && command -v pwsh >/dev/null 2>&1; then
    ( cd "$ROOT" && pwsh -NoProfile -File "$PS_CHECK" --all )
    rc=$?
    ran=1
fi

if [ "$ran" -eq 0 ]; then
    echo "[arch-check] 未找到可用检查器（arch-check.sh 需 bash / arch-check.ps1 需 pwsh），跳过门禁。" >&2
    echo "[arch-check] 提示：把 scripts/arch-check.* 放进工程，或设置 EMBEDDED_DEV_DIR 指向 skill 目录。" >&2
    exit 0
fi

if [ "$rc" -ne 0 ]; then
    echo "" >&2
    echo "[arch-check] ✗ 分层架构门禁未通过（上方为违规清单）。" >&2
    echo "[arch-check]   修复后再提交；确需临时跳过用：git commit --no-verify" >&2
    exit 1
fi

echo "[arch-check] ✓ 分层架构门禁通过" >&2
exit 0
