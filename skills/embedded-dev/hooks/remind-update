#!/usr/bin/env bash
# PostToolUse (Write|Edit|Bash) hook: remind Claude to update memory files
# after modifying code or running commands.
# Dual-track filename support; hooks fail open.

set +e

# 任一四文件存在即提醒（不仅限编辑清单）
found=""
for f in 编辑清单.md edits.md 项目规划清单.md plan.md 硬件资源表.md hw-resources.md 研究发现.md findings.md; do
  [ -f "$f" ] && found="$f" && break
done

if [ -n "$found" ]; then
  echo "[embedded-dev] 代码已修改，请按需更新：编辑清单(edits.md)、硬件资源表(hw-resources.md)、研究发现(findings.md)。"
fi

exit 0
